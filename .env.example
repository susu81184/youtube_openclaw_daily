# 复制此文件为 .env 并填入你的 API Key
# 务必不要把 .env 提交到 git

YOUTUBE_API_KEY=your_api_key_here

# 搜索
# YOUTUBE_SEARCH_QUERY=OpenClaw
# YOUTUBE_MAX_RESULTS=20
# 只搜最近多少小时内的新视频（72=近3天，便于抓到订阅频道更新）
# YOUTUBE_HOURS_SINCE=72

# 关注频道（二选一）：
# 方式一 OAuth 自动获取订阅：配置下面三项，然后运行 python auth_youtube.py 完成授权
# YOUTUBE_CLIENT_ID=xxx.apps.googleusercontent.com
# YOUTUBE_CLIENT_SECRET=xxx
# YOUTUBE_REFRESH_TOKEN=  # 运行 auth_youtube.py 后获得
# 方式二 手动填写 channel ID：
# YOUTUBE_CHANNEL_IDS=UCxxx,UCyyy

# 综合排序权重（得分=views*1+likes*100+comments*50+时间衰减加分）
# YOUTUBE_SORT_WEIGHT_VIEWS=1
# YOUTUBE_SORT_WEIGHT_LIKES=100
# YOUTUBE_SORT_WEIGHT_COMMENTS=50
# 时间衰减：发布越新加分越高，0=关闭
# YOUTUBE_SORT_WEIGHT_RECENCY=5000
# YOUTUBE_SORT_RECENCY_DAYS=100

# 搜索模式：0=首选 YouTube API，API 失败时自动用 DuckDuckGo；1=强制仅用 DuckDuckGo
# USE_WEB_SEARCH=0

# 输出
# YOUTUBE_OUTPUT_DIR=output

# Telegram 推送（可选）
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
